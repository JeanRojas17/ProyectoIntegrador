# Neon Database Configuration
# Database connection URL - includes connection pooling
DATABASE_URL=postgresql://your_user:your_password@your-host.neon.tech/neondb?channel_binding=require&sslmode=require

# Alternative: Individual credentials
DB_USER=your_user
DB_PASSWORD=your_password

# Neon Project Info
NEON_PROJECT_ID=your_project_id
NEON_ORG_ID=your_org_id
NEON_BRANCH=production
