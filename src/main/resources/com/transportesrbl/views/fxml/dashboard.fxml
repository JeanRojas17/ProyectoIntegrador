<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@../css/dashboard.css" 
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.transportesrbl.controllers.DashboardController">
    
    <left>
        <VBox prefWidth="250.0" styleClass="sidebar">
            <children>
                <VBox alignment="CENTER" spacing="10">
                    <padding>
                        <Insets top="30" right="0" bottom="30" left="0"/>
                    </padding>
                    <StackPane>
                        <Circle radius="40" fill="WHITE" stroke="#2c3e50" strokeWidth="2"/>
                        <Label text="RBL" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                    </StackPane>
                    <Label text="Transportes RBL" styleClass="sidebar-title"/>
                    <Label text="Sistema de Gestión" styleClass="sidebar-subtitle"/>
                </VBox>

                <Separator style="-fx-background-color: #3e4f5f;"/>

                <VBox spacing="5" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="20" right="10" bottom="0" left="10"/>
                    </padding>
                    <Button text="DASHBOARD" onAction="#mostrarSeccionDashboard" styleClass="menu-button" maxWidth="Infinity"/> 
                    <Button text="ASIGNACIONES" onAction="#mostrarSeccionAsignaciones" styleClass="menu-button" maxWidth="Infinity"/>
                    <Button text="PRODUCTOS" onAction="#MostrarSeccionProductos" styleClass="menu-button" maxWidth="Infinity"/>
                    <Button text="CAMIONES" onAction="#mostrarSeccionCamiones" styleClass="menu-button" maxWidth="Infinity"/>
                    <Button text="RUTAS" styleClass="menu-button" maxWidth="Infinity"/>
                    <Button text="PERSONAL" styleClass="menu-button" maxWidth="Infinity"/>
                    <Button text="REPORTES" styleClass="menu-button" maxWidth="Infinity"/>
                    <Button text="CONFIGURACION" styleClass="menu-button" maxWidth="Infinity"/>
                </VBox>

                <HBox spacing="15" styleClass="user-profile">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>    
                    <Circle radius="20" fill="#ecf0f1"/>
                    <VBox>
                        <Label fx:id="lblNombreUsuario" text="Juan Pérez" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label fx:id="lblRolUsuario" text="COORDINADOR LOGISTICO" style="-fx-text-fill: #bdc3c7; -fx-font-size: 10;"/>
                    </VBox>
                </HBox>                
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"> 
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f4f7f6;">
                <content>
                    <VBox spacing="20">
                        <padding>
                            <Insets top="25" right="25" bottom="25" left="25"/>
                        </padding>
                        
                        <HBox alignment="CENTER_LEFT" styleClass="header-box">
                            <padding>
                                <Insets top="15" right="20" bottom="15" left="20"/>
                            </padding>
                            <VBox HBox.hgrow="ALWAYS">
                                <Label text="DASHBOARD" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                                <Label text="GENERAL"/>
                            </VBox>
                            <HBox spacing="15" alignment="CENTER">
                                <VBox alignment="CENTER" styleClass="date-box">
                                    <Label text="Hoy: 28 Abr"/>
                                    <Label text="2026"/>
                                </VBox>
                                <Button text="Nueva Asignación" styleClass="action-button" onAction="#mostrarSeccionAsignaciones"/>
                            </HBox>
                        </HBox>

                        <FlowPane hgap="20" vgap="20" alignment="CENTER">
                            <children>
                                <VBox styleClass="stat-card">
                                    <Region prefHeight="100" style="-fx-background-color: #ecf0f1;"/>
                                    <VBox alignment="CENTER" spacing="5">
                                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                                        <Label fx:id="lblEntregasActivas" text="0" styleClass="card-number"/>
                                        <Label text="ENTREGAS ACTIVAS" styleClass="card-label"/>
                                    </VBox>
                                </VBox>
                                <VBox styleClass="stat-card">
                                    <Region prefHeight="100" style="-fx-background-color: #ecf0f1;"/>
                                    <VBox alignment="CENTER" spacing="5">
                                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                                        <Label fx:id="lblEntregasCompletas" text="0" styleClass="card-number"/>
                                        <Label text="ENTREGAS COMPLETADAS" styleClass="card-label"/>
                                    </VBox>
                                </VBox>
                                <VBox styleClass="stat-card">
                                    <Region prefHeight="100" style="-fx-background-color: #ecf0f1;"/>
                                    <VBox alignment="CENTER" spacing="5">
                                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                                        <Label fx:id="lblProductosPendientes" text="0" styleClass="card-number"/>
                                        <Label text="PRODUCTOS PENDIENTES" styleClass="card-label"/>
                                    </VBox>
                                </VBox>
                                <VBox styleClass="stat-card">
                                    <Region prefHeight="100" style="-fx-background-color: #ecf0f1;"/>
                                    <VBox alignment="CENTER" spacing="5">
                                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                                        <Label fx:id="lblCamionesDisponibles" text="0/0" styleClass="card-number"/>
                                        <Label text="CAMIONES DISPONIBLES" styleClass="card-label"/>
                                    </VBox>
                                </VBox>
                            </children>
                        </FlowPane>

                        <VBox spacing="10" styleClass="list-container">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="ENTREGAS RECIENTES:" styleClass="section-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Hyperlink text="VER TODAS---"/>
                            </HBox>
                            <TableView fx:id="tblEntregasRecientes" prefHeight="200">
                                <columns>
                                    <TableColumn fx:id="colProducto" text="Producto" prefWidth="250" />
                                    <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="300" />
                                    <TableColumn fx:id="colEstadoEntrega" text="Estado" prefWidth="150" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </VBox>

                        <VBox spacing="10" styleClass="list-container">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="ESTADO DE LA FLOTA:" styleClass="section-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Hyperlink text="VER DETALLES---"/>
                            </HBox>
                            <TableView fx:id="tblEstadoFlota" prefHeight="200">
                                <columns>
                                    <TableColumn fx:id="colModelo" text="Modelo Camión" prefWidth="250" />
                                    <TableColumn fx:id="colCapacidad" text="Capacidad (m³)" prefWidth="200" />
                                    <TableColumn fx:id="colEstadoCamion" text="Estado" prefWidth="250" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </StackPane>
    </center>
</BorderPane>