<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f4f7f6;" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.transportesrbl.controllers.CamionesController" stylesheets="@../css/camiones.css">
    
    <content>
        <VBox spacing="20">
            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>
            
            <HBox alignment="CENTER_LEFT" styleClass="header-box">
                <padding>
                    <Insets top="15" right="20" bottom="15" left="20"/>
                </padding>
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="GESTIÓN DE CAMIONES" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Administración y control de flota" style="-fx-text-fill: #7f8c8d;"/>
                </VBox>
                <Button text="+ Nuevo Camión" onAction="#handleNuevo" styleClass="action-button" style="-fx-background-color: #27ae60;"/>
            </HBox>

            <FlowPane hgap="20" vgap="20" alignment="CENTER">
                <children>
                    <VBox styleClass="list-container" prefWidth="200">
                        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                        <VBox alignment="CENTER" spacing="5">
                            <Label fx:id="lblTotalCamiones" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label text="TOTAL CAMIONES" styleClass="card-label"/>
                        </VBox>
                    </VBox>
                    <VBox styleClass="list-container" prefWidth="200">
                        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                        <VBox alignment="CENTER" spacing="5">
                            <Label fx:id="lblDisponibles" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label text="DISPONIBLES" styleClass="card-label"/>
                        </VBox>
                    </VBox>
                    <VBox styleClass="list-container" prefWidth="200">
                        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                        <VBox alignment="CENTER" spacing="5">
                            <Label fx:id="lblMantenimiento" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label text="MANTENIMIENTO" styleClass="card-label"/>
                        </VBox>
                    </VBox>
                    <VBox styleClass="list-container" prefWidth="200">
                        <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                        <VBox alignment="CENTER" spacing="5">
                            <Label fx:id="lblCapacidadTotal" text="0.0 m³" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label text="CAPACIDAD TOTAL" styleClass="card-label"/>
                        </VBox>
                    </VBox>
                </children>
            </FlowPane>

            <HBox spacing="15" alignment="BOTTOM_LEFT" styleClass="list-container">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <VBox spacing="5">
                    <Label text="BUSCAR" styleClass="card-label"/>
                    <TextField fx:id="txtBuscar" promptText="Modelo..." prefWidth="200"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="ESTADO" styleClass="card-label"/>
                    <ComboBox fx:id="cbEstado" prefWidth="150" promptText="Seleccionar"/>
                </VBox>
                
                <Region HBox.hgrow="ALWAYS" />

                <HBox spacing="10" alignment="BOTTOM_RIGHT">
                    <Button text="Modificar" onAction="#handleModificar" styleClass="action-button" style="-fx-background-color: #f39c12;" />
                    <Button text="Eliminar" onAction="#handleEliminar" styleClass="action-button" style="-fx-background-color: #e74c3c;" />
                    <Button text="Limpiar" onAction="#handleLimpiar" styleClass="secondary-button"/>
                </HBox>
            </HBox>

            <VBox VBox.vgrow="ALWAYS" styleClass="list-container" prefHeight="400">
                <TableView fx:id="tblCamiones" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                        <TableColumn fx:id="colModelo" text="MODELO" prefWidth="250"/>
                        <TableColumn fx:id="colCapacidad" text="CAPACIDAD (m³)" prefWidth="150"/>
                        <TableColumn fx:id="colEstado" text="ESTADO" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
