<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="main-container" stylesheets="@asignaciones.css" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.transportesrbl.controllers.AsignacionesController">
    
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- Encabezado de Sección -->
    <HBox alignment="CENTER_LEFT" styleClass="header-box">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20"/>
        </padding>
        <VBox HBox.hgrow="ALWAYS">
            <Label text="GESTIÓN DE TRANSPORTE" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Asignaciones de Camiones y Rutas" style="-fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Button text="+ Nueva Asignación" onAction="#handleNuevo" styleClass="action-button"/>
    </HBox>

    <!-- Panel de Filtros -->
    <HBox spacing="15" alignment="BOTTOM_LEFT" styleClass="list-container">
        <padding>
            <Insets top="15" right="15" bottom="15" left="15"/>
        </padding>
        <VBox spacing="5">
            <Label text="Buscar Producto" styleClass="card-label"/>
            <TextField fx:id="txtBuscar" promptText="Ej: Arroz..." prefWidth="150"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Estado" styleClass="card-label"/>
            <ComboBox fx:id="cbEstado" prefWidth="130" promptText="Seleccionar"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Fecha" styleClass="card-label"/>
            <DatePicker fx:id="dpFecha" prefWidth="130"/>
        </VBox>
        
        <Region HBox.hgrow="ALWAYS" />

        <!-- Nuevos botones para Modificar y Eliminar -->
        <HBox spacing="10">
            <Button text="Modificar" onAction="#handleModificar" styleClass="action-button" style="-fx-background-color: #f39c12;"/>
            <Button text="Eliminar" onAction="#handleEliminar" styleClass="action-button" style="-fx-background-color: #e74c3c;"/>
            <Button text="Limpiar Filtros" onAction="#handleLimpiar" styleClass="secondary-button"/>
        </HBox>
    </HBox>

    <!-- Tabla de Datos -->
    <VBox VBox.vgrow="ALWAYS" styleClass="list-container">
        <TableView fx:id="tblAsignaciones" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colCamion" text="Camión" prefWidth="120"/>
                <TableColumn fx:id="colConductor" text="Conductor" prefWidth="180"/>
                <TableColumn fx:id="colRuta" text="Ruta" prefWidth="150"/>
                <TableColumn fx:id="colProducto" text="Producto" prefWidth="150"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="120"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>